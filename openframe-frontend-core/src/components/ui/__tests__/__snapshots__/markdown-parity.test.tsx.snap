    .mermaid-svg-container .node text,
    .mermaid-svg-container .edgeLabel text { font-size: 14px !important; }
  }
  @media (min-width: 1520px) {
    .mermaid-svg-container .node text,
    .mermaid-svg-container .edgeLabel text { font-size: 16px !important; }
  }
</style><div class="content-wrapper max-w-none"><article class="prose prose-lg max-w-none"><img alt="No image available" width="400" height="400" style="width: auto; height: auto;" class="max-w-full max-h-[400px] w-auto h-auto rounded-lg object-contain" src="https://example.com/x.png"></article></div></div>"
`;

